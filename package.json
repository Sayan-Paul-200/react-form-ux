{
  "name": "react-form-ux",
  "version": "0.1.0",
  "description": "UX helpers for React forms (focus errors, scroll to validation, error summaries).",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "keywords": [
    "react",
    "react-hook-form",
    "forms",
    "form-validation",
    "form-ux",
    "frontend",
    "react-forms",
    "validation",
    "accessibility"
  ],
  "author": "Sayan Paul",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
